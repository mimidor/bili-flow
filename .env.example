# =========================
# 1. 最小可运行
# 只想先启动后台并登录，先填这一组
# =========================
ADMIN_AUTH_USERNAME=admin
ADMIN_AUTH_PASSWORD=change-me-now
ADMIN_AUTH_SECRET=replace-with-a-random-secret

# =========================
# 2. B 站主链路
# 想打通 视频/动态 -> 总结 -> 飞书推送，必须继续补这一组
# =========================
BILIBILI_COOKIE=
refresh_token=
VIDEO_CHECK_INTERVAL=10
DYNAMIC_CHECK_INTERVAL=5

# =========================
# 3. LLM
# =========================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
LLM_INPUT_TOKEN_PRICE_PER_MILLION=2
LLM_OUTPUT_TOKEN_PRICE_PER_MILLION=12

# =========================
# 4. 飞书推送
# =========================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=chat_id

# 兼容保留，当前主链路不依赖 webhook
FEISHU_WEBHOOK=

# 飞书文档（按需启用）
FEISHU_DOCS_ENABLED=false
FEISHU_DOCS_FOLDER_TOKEN=
FEISHU_DOCS_SPACE_ID=

# =========================
# 5. 数据库与系统
# =========================
DATABASE_SOURCE=sqlite
SQLITE_DATABASE_URL=sqlite:///data/bili.db
POSTGRESQL_DATABASE_URL=
LOG_LEVEL=INFO
FFMPEG_LOCATION=

# =========================
# 6. 本地 / 云 ASR
# =========================
ASR_PROVIDER=local_whisper

# 阿里云百炼 ASR（按需启用）
DASHSCOPE_API_KEY=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PREFIX=bili-flow/asr

# 本地 Whisper
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_LOG_PROGRESS=true
USE_WHISPER_CPP=false
WHISPER_CPP_CLI=
WHISPER_CPP_MODEL=

# 本地 Qwen3-ASR
LOCAL_ASR_ENGINE=whisper
QWEN3_ASR_MODEL_SOURCE=modelscope
QWEN3_ASR_MODEL_ID=Qwen/Qwen3-ASR-0.6B
QWEN3_ASR_MODEL_DIR=
QWEN3_ASR_HF_ENDPOINT=https://hf-mirror.com

# =========================
# 7. 小宇宙
# =========================
XYZ_BASE_URL=
XYZ_DEVICE_ID=
XYZ_ACCESS_TOKEN=
XYZ_REFRESH_TOKEN=
XYZ_CHECK_INTERVAL=10
XYZ_BOOTSTRAP_RECENT_EPISODES=3
XYZ_MAX_PAGES_PER_POLL=5

# =========================
# 8. WeWe RSS（未完全实现）
# =========================
WEWE_RSS_BASE_URL=
WEWE_RSS_AUTH_CODE=
WEWE_RSS_CHECK_INTERVAL=10

# =========================
# 9. 本地视频扫描（按需启用）
# =========================
LOCAL_VIDEO_SCAN_DIRS=
LOCAL_VIDEO_SCAN_INTERVAL=0
LOCAL_VIDEO_SCAN_PUSH_TARGET_ID=0

# =========================
# 10. 静音时间（按需启用）
# =========================
SILENT_MODE_START=
SILENT_MODE_END=

# =========================
# 11. Qteasy（未完全实现）
# =========================
QTEASY_API_URL=
